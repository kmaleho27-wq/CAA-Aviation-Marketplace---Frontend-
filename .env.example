# ── Naluka frontend ────────────────────────────────────────────
# Supabase connection (browser-safe — these are exposed in the bundle).
# Get from: https://app.supabase.com → your project → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Mock-API toggle (UI-demo mode):
#   true  → frontend uses canned fixtures, never hits Supabase
#   false → real Supabase (default for prod)
VITE_USE_MOCK_API=true

# Legacy axios path. Only read while VITE_USE_MOCK_API=true so the existing
# mock adapter continues to intercept calls. Safe to leave as-is.
VITE_API_URL=http://localhost:5000/api

# ──────────────────────────────────────────────────────────────────
# NEVER prefix the service-role key with VITE_. It bypasses RLS and
# must only live in Edge Functions (set via `supabase secrets set`)
# or in scripts/seed-supabase.mjs (read from a separate non-VITE var
# at runtime). Putting it in a VITE_ var ships it to every browser.
# ──────────────────────────────────────────────────────────────────

# Used ONLY by scripts/seed-supabase.mjs (Node, not Vite). Do NOT commit.
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
